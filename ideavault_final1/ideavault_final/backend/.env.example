# Google Gemini (AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Use a model your key supports on v1beta generateContent (avoid deprecated / wrong IDs).
# Examples: gemini-2.0-flash, gemini-2.5-flash-preview-05-20, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated fallbacks if the primary returns 404 or is overloaded:
GEMINI_MODEL_FALLBACKS=gemini-1.5-flash,gemini-1.5-pro,gemini-2.5-flash-preview-05-20

# Display conversion for USD amounts shown as ₹ in UI (optional)
USD_TO_INR=83

# Optional: Anthropic when Gemini is not configured
ANTHROPIC_API_KEY=

GROQ_API_KEY=
# Optional second key (used if the first hits rate limits / errors):
GROQ_API_KEY_2=
# Or multiple keys in one line (comma-separated):
# GROQ_API_KEYS=key1,key2
# Comma-separated provider order for AI fallbacks: gemini,groq,openrouter
AI_PROVIDER_ORDER=gemini,groq,openrouter

EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
# Use the same database name as in MongoDB Compass (case-sensitive on some hosts).
# Either name works: MONGODB_URI (preferred) or MONGO_URI (legacy).
MONGODB_URI=mongodb://localhost:27017/IDEAVAULT
PORT=5000
JWT_SECRET=ideavault_secret_2026
